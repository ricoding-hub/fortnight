# Supabase — Dashboard > Settings > API
VITE_SUPABASE_URL=your_project_url
VITE_SUPABASE_KEY=your_anon_key

# ---- Server-only (Vercel project env vars; never prefix with VITE_) ----

# Unprefixed Supabase URL used by Vercel Functions (same value as VITE_SUPABASE_URL).
SUPABASE_URL=your_project_url

# Service-role key for the Vercel Functions under /api to write on behalf
# of the authenticated user. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Syncfy bank-aggregation credentials. The widget uses a short-lived token
# minted by the server; the API key below is the long-lived secret that
# stays in Vercel env only.
SYNCFY_API_KEY=your_syncfy_api_key
SYNCFY_BASE_URL=https://sync.paybook.com/v1

# Resend — transactional emails via the Vercel cron route (resend.com, free: 100/day)
# Set these in Vercel Dashboard > Settings > Environment Variables.
# For testing without a verified domain, use FROM_EMAIL=onboarding@resend.dev
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=Richeto <no-reply@yourdomain.com>

# Secret used by Vercel to authenticate its own cron invocations.
# Set in Vercel Dashboard > Settings > Environment Variables.
# Generate with: openssl rand -hex 32
CRON_SECRET=your_random_secret_here
